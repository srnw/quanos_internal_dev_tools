# MongoDB connection string
MONGODB_URI=mongodb://root:example@localhost:27017/devtools?authSource=admin

# Secret used to sign JWT tokens — change this in production
JWT_SECRET=change-me-in-production

# JWT expiry (e.g. 1h, 7d)
JWT_EXPIRES_IN=1h

# Admin credentials used to authenticate via POST /api/auth/login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Port the NestJS server listens on
PORT=3000
